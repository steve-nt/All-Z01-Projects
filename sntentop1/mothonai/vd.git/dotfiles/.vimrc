call plug#begin()

Plug 'neoclide/coc.nvim', { 'branch': 'release' }
Plug 'airblade/vim-gitgutter'
Plug 'tpope/vim-fugitive'
Plug 'tpope/vim-dadbod'
Plug 'kristijanhusak/vim-dadbod-ui'

call plug#end()

filetype plugin on
colorscheme ayu
set autoindent
set colorcolumn=80
set cursorline
set expandtab
set modelines=0
set mouse=a
set nocompatible
set noswapfile
set number
set relativenumber
set shiftwidth=4
set shiftwidth=4
set showmatch
set softtabstop=4
set tabstop=4
set termguicolors
syntax on
verbose set cursorline
