function _vd_setup_rust(){
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    vim -c 'CocInstall -sync coc-rust-analyzer|qa' > /dev/null 2>&1
    source ${HOME}/.cargo/env
}
