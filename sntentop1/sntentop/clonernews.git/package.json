{
  "name": "clonernews",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A polished Hacker News client built with vanilla JavaScript and Vite.",
  "scripts": {
    "dev": "vite --open /",
    "build": "vite build",
    "preview": "vite preview",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ci:guards": "node ./scripts/ci-guards.mjs",
    "ci:quality": "npm run check && npm run ci:guards && npm run test && npm run test:e2e && npm run build",
    "ci:policy": "node ./scripts/policy-gate.mjs",
    "ci": "npm run ci:quality",
    "ci:all": "npm run ci:quality && npm run ci:policy"
  },
  "dependencies": {
    "dompurify": "^3.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@js-temporal/polyfill": "^0.5.1",
    "@playwright/test": "^1.52.0",
    "jsdom": "^26.1.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  }
}
